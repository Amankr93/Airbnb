<%- include('../partials/head') %>
<body>
<%- include('../partials/header') %>
   <main>
        <h1 class=" text-red-400 text-3xl font-bold my-8 text-center"><%= bookings.length > 0 ? 'Here are your bookings:' : 'You have no bookings.' %></h1>
        
       <div class="flex justify-center gap-[40px] space-y-5 flex-wrap max-w-[400px] sm:max-w-[650px] lg:max-w-[1000px] mx-auto my-8">
          <% bookings.forEach((home)=>{ %>
            <div class="border w-[300px] rounded-md px-3 py-2 shadow-2xl">
                <div class="h-[200px] mb-4">
                    <img src="/<%= home.photo%>" alt="" class="h-full w-full">

                </div>
                <div class="flex justify-between">
                    <h3 class="font-bold text-[18px] capitalize"><%= home.houseName %></h3>
                    <p class="font-semibold text-[14px]"><%= home.rating%></p>
                </div>
                <div class="font-semibold"><%= home.location%></div>
                <div>
                    <span class="text-[14px] font-semibold">Rs. <%= home.price%> /night</span>
                </div>
                <!-- <div class="my-3 flex justify-between">
                    <a href="/homes/<%= home._id %>" class="bg-red-500 px-1 py-1 rounded-md text-white">View Details</a>
                    <form action="/favourites/delete/<%= home._id%>" method="post">

                        <button type="submit" class="bg-red-500 px-1 py-1 rounded-md text-white">Remove From Favourite</button>
                    </form>
                   
                </div> -->

            </div>
           <% })%> 
        
       </div>
          
        
    </main>

</body>