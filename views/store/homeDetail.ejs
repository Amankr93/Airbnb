<%- include('../partials/head') %>
<body>
    <main>
        <div class="border w-75 rounded-md px-5 py-3 shadow-2xl mx-auto md:flex justify-between mt-10  md:w-[750px]">
                 <div class="h-[250px] mb-4 md:w-[320px] ">
                    <img src="/<%= home.photo%>" alt="" class="h-full w-full">

                </div>
                <div class="md:w-[320px] h-full md:h-[250px] md:relative">
                    <div class="flex justify-between ">
                        <h3 class="font-bold text-[18px] capitalize"><%= home.houseName %></h3>
                        <p class="font-semibold text-[14px]"> <span style="color: gold; font-size: 24px;">&#9733</span> <%= home.rating%></p>
                    </div>
                <div class="font-semibold capitalize"><%= home.location%></div>
                <div>
                    <span class="text-[14px] font-semibold">Rs. <%= home.price%> /night</span>
                </div>
                <div>
                    <%= home.description %>
                </div>
                <div>
                    <a href="/homeRule/<%= home._id%>" class="text-blue-900 font-semibold underline decoration-dotted">Home Rules</a>
                </div>
                <div class="my-3 md:my-0 flex justify-between w-full md:absolute md:bottom-[0px]">
                   <%- include('../partials/favourite') %>
                   <form action="/bookings/<%= home._id%>" method="post">
                    <button type="submit" class="bg-red-500 px-2 py-1 rounded-md text-white">Book Home</button>
                   </form>
                    
                    
                </div>

            </div>
                </div>
                
    </main>

</body>