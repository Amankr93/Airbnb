
<%- include('../partials/head') %>
<body>
    <%-  include('../partials/header') %>
    
     <main>
       <div class="flex justify-center gap-10 space-y-5 flex-wrap max-w-100 sm:max-w-162.5 lg:max-w-250 mx-auto my-8">
          <% registeredHomes.forEach((home)=>{ %>
            <div class="border w-75 rounded-md px-3 py-2 shadow-2xl">
                 <div class="h-[200px] mb-4">
                    <img src="/<%= home.photo%>" alt="" class="h-full w-full">

                </div>
                <div class="flex justify-between">
                    <h3 class="font-bold text-[18px] capitalize"><%= home.houseName %></h3>
                    <p class="font-semibold text-[14px]"><%= home.rating%></p>
                </div>
                <div class="font-semibold"><%= home.location%></div>
                <div>
                    <span class="text-[14px] font-semibold">Rs. <%= home.price%> /night</span>
                </div>
                <div class="my-3 flex justify-between">
                    <a href="/homes/<%= home._id %>" class="bg-red-500 px-2 py-1 rounded-md text-white">View Details</a>
                    <%- include('../partials/favourite' , {home}) %>
                </div>
                <div class="my-3 flex justify-between">
                   
                    
                    
                </div>

            </div>
           <% })%> 
        
       </div>
          
        
    </main>
</body>
</html>