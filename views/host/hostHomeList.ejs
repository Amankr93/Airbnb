
<%- include('../partials/head') %>
<body>
    <%-  include('../partials/header') %>
    
        
    <main>
        <h1 class=" text-red-400 text-3xl font-bold my-8 text-center"><%= registeredHomes.length > 0 ? 'Here are your homes:' : 'You have no registered homes.' %></h1>
       <div class="flex justify-center gap-[40px] space-y-5 flex-wrap max-w-[400px] sm:max-w-[650px] lg:max-w-[1000px] mx-auto my-8">
          <% registeredHomes.forEach((home)=>{ %>
            <div class="border w-[300px] rounded-md px-3 py-2 shadow-2xl">
                 <div class="h-[200px] mb-4">
                    <img src="/<%= home.photo%>" alt="" class="h-full w-full">

                </div>
                <div class="flex justify-between">
                    <h3 class="font-bold text-[18px] capitalize"><%= home.houseName %></h3>
                    <p class="font-semibold text-[14px]"><%= home.rating%></p>
                </div>
                <div class="font-semibold"><%= home.location%></div>
                <div>
                    <span class="text-[14px] font-semibold">Rs. <%= home.price%> /night</span>
                </div>
                <!-- <div class="my-3 flex justify-between">
                    <a href="" class="bg-red-500 px-2 py-1 rounded-md text-white">View Details</a>
                    <a href="" class="bg-red-500 px-2 py-1 rounded-md text-white ">Add to Favourite</a>
                </div> -->
                <div class="my-3 flex justify-between"> 
                    <a href="/host/editHome/<%=home._id.toString() %>?editing=true" class="bg-red-500 w-[40%] text-center px-2 py-1 rounded-md text-white">Edit</a>
                    <form action="/host/deleteHome/<%=home._id%>" method="post" class="w-[40%]">
                        <button type="submit" class="bg-red-500 px-2 py-1 rounded-md text-white w-full text-center" >Delete</button>
                    </form>
                    
                </div>

            </div>
           <% })%> 
        
       </div>
          
        
    </main>
</body>
</html>