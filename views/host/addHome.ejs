<%- include('../partials/head') %>

<body>
        <%- include('../partials/header') %>

        
        
    
    <main>
        <h1 class="text-red-500 text-3xl font-bold text-center my-4 "><%=editing?"Edit":"Register" %> Your Home</h1>
        <div class=" px-3 mx-auto max-w-[400px] md:max-w-[600px] lg:max-w-[600px]  px-2 mt-10 ">
            
        <form action="/host/<%= editing?'editHome':'addHome'%>/<%=editing?home._id:'' %>" method="post" class="flex flex-col  justify-between h-full gap-2"
            enctype="multipart/form-data"
            >
        <input type="text"
        
        placeholder="enter your House Name"
        name="houseName"
        class="outline-none border border-gray-500 rounded-md h-[35px] px-2 placeholder:capitalize"
        value="<%= editing? home.houseName:"" %>"
        >
        <input type="text"
        placeholder="Price per night"
        name="price"
        value="<%= editing? home.price:"" %>"
        class="outline-none border border-gray-500 rounded-md h-[35px] px-2 placeholder:capitalize"
        >   
        <input type="text"
        placeholder="Location"
        name="location"
        value="<%= editing? home.location:"" %>"
        class="outline-none border border-gray-500 rounded-md h-[35px] px-2 placeholder:capitalize"
        >   
        <input type="text"
        placeholder="Rating"
        name="rating"
        value="<%= editing? home.rating:"" %>"
        class="outline-none border border-gray-500 rounded-md h-[35px] px-2 placeholder:capitalize"
        >   
        <label class="block text-sm font-medium">Uploads</label>
        <div class="flex items-start gap-4">
            <div class="flex items-center gap-2">
                <label for="photo" class="cursor-pointer inline-flex items-center px-3 py-1 bg-gray-100 border rounded-md hover:bg-gray-200 text-sm text-gray-700">
                    <span id="photoButtonText">Choose photo</span>
                    <input id="photo" type="file" name="photo" accept="image/*" required class="sr-only">
                </label>
                <span id="photoFileName" class="text-sm text-gray-600 max-w-[160px] truncate"></span>
            </div>
            <div class="flex items-center gap-2">
                <label for="rule" class="cursor-pointer inline-flex items-center px-3 py-1 bg-gray-100 border rounded-md hover:bg-gray-200 text-sm text-gray-700">
                    <span>Upload rules (PDF)</span>
                    <input id="rule" type="file" name="rule" accept="application/pdf,.pdf" class="sr-only">
                </label>
                <span id="ruleFileName" class="text-sm text-gray-600 max-w-[160px] truncate"></span>
            </div>
        </div>
        

        <textarea name="description" id="description" 
        placeholder="Enter Home Description"
        rows="3"
        class="outline-none border resize-none border-gray-500 rounded-md  px-2 placeholder:capitalize"></textarea>
        <input type="submit" value="<%= editing? 'Update':'submit' %>" class="bg-red-500 py-1.5 my-3 text-white font-semibold text-[18px] rounded-md capitalize">
    </form>
    
        </div>
        
    </main>
    
</body>
<script>
    (function(){
        const photoInput = document.getElementById('photo');
        const photoFileName = document.getElementById('photoFileName');
        const photoPreview = document.getElementById('photoPreview');
        const ruleInput = document.getElementById('rule');
        const ruleFileName = document.getElementById('ruleFileName');

        if(photoInput){
            photoInput.addEventListener('change', function(){
                const file = this.files[0];
                if(!file){ photoFileName.textContent = ''; photoPreview.classList.add('hidden'); return; }
                photoFileName.textContent = file.name;
                if(file.type && file.type.startsWith('image/')){
                    const reader = new FileReader();
                    reader.onload = function(e){ photoPreview.src = e.target.result; photoPreview.classList.remove('hidden'); }
                    reader.readAsDataURL(file);
                } else {
                    photoPreview.classList.add('hidden');
                }
            });
        }

        if(ruleInput){
            ruleInput.addEventListener('change', function(){
                const file = this.files[0];
                ruleFileName.textContent = file ? file.name : '';
            });
        }
    })();
</script>
</html>